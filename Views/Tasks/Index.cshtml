@model IEnumerable<ToDoList.Models.TaskItem>

@{
	ViewData["Title"] = "Tasks List";
}

<h1>Your Tasks</h1>

<a asp-action="Create" class="btn btn-primary mb-3">Create New Task</a>

<table class="table">
	<thead>
		<tr>
			<th scope="col">Title</th>
			<th scope="col">Description</th>
			<th scope="col">Status</th>
			<th scope="col">Created At</th>
			<th></th>
			<th></th>
		</tr>
	</thead>
	<tbody>
		@foreach(var task in Model)
		{
			<tr>
				<td>@task.Title</td>
				<td>@task.Description</td>
				<td>@task.Status</td>
				<td>@task.CreatedAt</td>
				<td><a asp-action="Edit" asp-route-id="@task.Id" class="btn btn-sm btn-warning">Editar</a></td>
				<td><a asp-action="Delete" asp-route-id="@task.Id" class="btn btn-sm btn-danger">Excluir</a></td>
			</tr>
		}
	</tbody>
</table>
